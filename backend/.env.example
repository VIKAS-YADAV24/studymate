# These are runtime secrets for Supabase Edge Functions.
# Set them via: supabase secrets set KEY=value  (or in the Lovable Cloud dashboard)
# DO NOT commit a real .env file.

LOVABLE_API_KEY="your-lovable-ai-gateway-key"

